# Cloudflare Pages Functions — Local Development Variables
# Copy this file to .env and fill in your values.
# Wrangler reads .dev.vars at runtime (the Taskfile copies .env → .dev.vars).

# Turnstile
# Site key: public, used at build time by Astro
PUBLIC_TURNSTILE_SITE_KEY=
# Secret key: used at runtime by Pages Functions
# Test keys — Always pass: 1x0000000000000000000000000000000AA / Always fail: 2x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Contact form recipients
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
